#!/bin/bash
set -euo pipefail

LABEL="com.mac-cleaner.menubar"
PLIST="${HOME}/Library/LaunchAgents/${LABEL}.plist"

if [ ! -f "$PLIST" ]; then
  echo "Launch Agent not installed."
  exit 0
fi

launchctl unload "$PLIST" 2>/dev/null || true
rm -f "$PLIST"

echo "Menubar widget removed. It will no longer start on login."
